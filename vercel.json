{
  "crons": [
    {
      "path": "/api/cron/sync-practiceq-appointments",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/monthly-provider-transitions",
      "schedule": "0 9 1 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/labs/api/:path*",
      "destination": "https://lab-requisition-tool.vercel.app/api/:path*"
    },
    {
      "source": "/labs",
      "destination": "https://lab-requisition-tool.vercel.app/labs"
    },
    {
      "source": "/labs/:path*",
      "destination": "https://lab-requisition-tool.vercel.app/labs/:path*"
    }
  ]
}
